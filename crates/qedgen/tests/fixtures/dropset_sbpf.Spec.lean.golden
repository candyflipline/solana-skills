    ∀ (inputAddr insnAddr : Nat) (mem : Mem) (_h_discriminant : readU8 mem insnAddr = DISC_REGISTER_MARKET) (nAccounts : Nat) (_h_nAccounts_val : readU64 mem inputAddr = nAccounts) (_h_nAccounts_ge : ¬(nAccounts < ACCOUNTS_REQUIRED)) (_h_insnLen : readU64 mem (insnAddr - 8) = INSTRUCTION_DATA_LEN) (_h_userDataLen : readU64 mem (inputAddr + 88) = DATA_LEN_ZERO) (_h_marketDup : readU8 mem (inputAddr + 10344) = ACCT_NON_DUP_MARKER) (_h_marketDataLen : readU64 mem (inputAddr + 10424) = DATA_LEN_ZERO) (_h_baseMintDup : readU8 mem (inputAddr + 20680) = ACCT_NON_DUP_MARKER) (_h_marketPubkey : readU64 mem (inputAddr + 10352) = derived_pda),
    (executeFn progAt (initState2 inputAddr insnAddr mem 24) 96).exitCode = some E_RENT_SYSVAR_IS_DUPLICATE
  rejects_invalid_rent_sysvar_pubkey :
    ∀ (inputAddr insnAddr : Nat) (mem : Mem) (_h_discriminant : readU8 mem insnAddr = DISC_REGISTER_MARKET) (nAccounts : Nat) (_h_nAccounts_val : readU64 mem inputAddr = nAccounts) (_h_nAccounts_ge : ¬(nAccounts < ACCOUNTS_REQUIRED)) (_h_insnLen : readU64 mem (insnAddr - 8) = INSTRUCTION_DATA_LEN) (_h_userDataLen : readU64 mem (inputAddr + 88) = DATA_LEN_ZERO) (_h_marketDup : readU8 mem (inputAddr + 10344) = ACCT_NON_DUP_MARKER) (_h_marketDataLen : readU64 mem (inputAddr + 10424) = DATA_LEN_ZERO) (_h_baseMintDup : readU8 mem (inputAddr + 20680) = ACCT_NON_DUP_MARKER) (_h_marketPubkey : readU64 mem (inputAddr + 10352) = derived_pda),
    (executeFn progAt (initState2 inputAddr insnAddr mem 24) 108).exitCode = some E_INVALID_RENT_SYSVAR_PUBKEY

