# OS files
.DS_Store
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.iml

# Test outputs
/tmp/
*.tmp
.cache/

# Logs
*.log

# Anchor/Solana
.anchor/
target/
test-ledger/
# Cargo.lock is tracked for binaries but not for libraries
package-lock.json
yarn.lock

# Built binaries — downloaded from GitHub releases by install.sh
bin/

# Leanstral verification artifacts
**/lean_proofs/*_raw.txt
**/lean_proofs/metadata.json
**/lean_proofs/prompt.txt
**/.qedgen/
**/.leanstral/

# Lean build artifacts
.lake/
*.olean
*.olean.trace
*.old

# PRDs (internal planning docs) stay local; release notes track in-repo.
docs/prds/*
!docs/prds/RELEASE-*.md

# Research notes / prior-art comparisons stay local; the source material
# names external projects we don't cite in public artifacts.
docs/research/

# Internal learnings / reconnaissance — source material for probes and
# lints, never committed to the public repo (see feedback memory: no
# naming sources of finding in public artifacts).
learnings/
LEARNINGS_*.md

# Audit findings: per-target eval outputs and rollups stay local. They
# may name external source codebases (per-target attribution for
# internal traceability) and contain unreleased exploit primitives;
# never commit. The auditor SKILL.md / exploits.md / release notes
# carry the *generic* taxonomy; the source-attributed findings here do
# not.
.qed/findings/

# Transient feedback artifacts. `qedgen feedback` writes local drafts to
# `.qed/feedback/<ts>.md` before submission; `main()`'s error path captures
# the most recent failure's stderr to `.qed/last-error.{log,json}` so the
# next `qedgen feedback` invocation has context. Both are user-machine
# state, not repo content. (`*.log` above already covers .log; the JSON
# and the feedback directory need explicit entries.)
.qed/feedback/
.qed/last-error.json

# Local agent/editor state
.agents/
.claude/*
# ...but track shared path-scoped rules
!.claude/rules/
\n# Generated proof artifacts\nlean_project/\nqedgen_*/
tests/kani.rs
